# The People's Elbow .gitignore

# Private strategy documents
agenthandoff.md
**/agenthandoff.md
feature_wishlist.md
**/feature_wishlist.md

# System and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Logs
logs
*.log
npm-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build directories
dist/
build/
out/
.next/
devring_overhaul.md
node_modules

# Wrangler / Miniflare local state — leaks CF account id, home geolocation, dev DBs.
# These were committed before this rule existed; untracked via `git rm --cached`.
.wrangler/
**/.wrangler/
.mf/
**/.mf/
*.sqlite
*.sqlite-shm
*.sqlite-wal
.dev.vars

# Private business planning — must never reach the public deploy.
woodstock-plan.html

# Claude Code session state
.claude/
